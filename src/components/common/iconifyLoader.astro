---
// 全局Iconify加载器组件

export interface Props {
    preloadIcons?: string[];
}

const { preloadIcons = [] } = Astro.props;
---

<!-- 内联加载逻辑: 按需动态注入 CDN 脚本，然后处理图标渲染 -->
<script define:vars={{ preloadIcons }}>
    (function() {
        'use strict';

        if (window.__iconifyLoaderInitialized) {
            return;
        }
        window.__iconifyLoaderInitialized = true;

        class IconifyLoader {
            constructor() {
                this.isLoaded = false;
                this.observers = new Set();
                this.preloadQueue = new Set(preloadIcons);
            }

            onLoad(callback) {
                if (this.isLoaded) {
                    callback();
                } else {
                    this.observers.add(callback);
                }
            }

            injectScript() {
                return new Promise((resolve, reject) => {
                    if (typeof customElements !== 'undefined' && customElements.get('iconify-icon')) {
                        resolve();
                        return;
                    }
                    const existing = document.querySelector('script[src*="iconify-icon"]');
                    if (existing) {
                        if (customElements.whenDefined) {
                            customElements.whenDefined('iconify-icon').then(resolve).catch(reject);
                        } else {
                            const check = () => {
                                if (customElements && customElements.get('iconify-icon')) {
                                    resolve();
                                } else {
                                    requestAnimationFrame(check);
                                }
                            };
                            check();
                        }
                        return;
                    }
                    const script = document.createElement('script');
                    script.src = 'https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js';
                    script.onload = resolve;
                    script.onerror = () => { script.remove(); reject(new Error('CDN script load failed')); };
                    document.head.appendChild(script);
                });
            }

            waitForReady() {
                if (typeof customElements !== 'undefined' && customElements.get('iconify-icon')) {
                    return Promise.resolve();
                }
                if (typeof customElements !== 'undefined' && customElements.whenDefined) {
                    return customElements.whenDefined('iconify-icon');
                }
                return new Promise((resolve) => {
                    const check = () => {
                        if (customElements && customElements.get('iconify-icon')) {
                            resolve();
                        } else {
                            requestAnimationFrame(check);
                        }
                    };
                    check();
                });
            }

            forceRefresh() {
                document.querySelectorAll('iconify-icon').forEach(el => {
                    const icon = el.getAttribute('icon');
                    if (icon) {
                        el.removeAttribute('icon');
                        requestAnimationFrame(() => el.setAttribute('icon', icon));
                    }
                });
            }

            setupObserver() {
                if (this._observer) return;
                const loader = this;
                this._observer = new MutationObserver((mutations) => {
                    if (!loader.isLoaded) return;
                    mutations.forEach(mutation => {
                        mutation.addedNodes.forEach(node => {
                            if (node.nodeType === 1) {
                                if (node.tagName === 'ICONIFY-ICON') {
                                    loader.refreshNode(node);
                                }
                                if (node.querySelectorAll) {
                                    node.querySelectorAll('iconify-icon').forEach(el => loader.refreshNode(el));
                                }
                            }
                        });
                    });
                });
                this._observer.observe(document.body, { childList: true, subtree: true });
            }

            refreshNode(el) {
                const icon = el.getAttribute('icon');
                if (icon) {
                    el.removeAttribute('icon');
                    requestAnimationFrame(() => el.setAttribute('icon', icon));
                }
            }

            notifyObservers() {
                this.observers.forEach(cb => { try { cb(); } catch (e) { console.error(e); } });
                this.observers.clear();
            }

            addToPreloadQueue(icons) {
                if (Array.isArray(icons)) {
                    icons.forEach(icon => this.preloadQueue.add(icon));
                } else {
                    this.preloadQueue.add(icons);
                }
                if (this.isLoaded) {
                    this.processPreloadQueue();
                }
            }

            processPreloadQueue() {
                if (this.preloadQueue.size === 0) return;
                const icons = Array.from(this.preloadQueue);
                this.preloadQueue.clear();
                icons.forEach(icon => {
                    const el = document.createElement('iconify-icon');
                    el.setAttribute('icon', icon);
                    el.style.cssText = 'display:none';
                    document.body.appendChild(el);
                    requestAnimationFrame(() => {
                        if (el.parentNode) el.parentNode.removeChild(el);
                    });
                });
            }

            async load() {
                if (this.isLoaded) {
                    return Promise.resolve();
                }
                try {
                    await this.injectScript();
                    await this.waitForReady();
                    this.isLoaded = true;
                    this.forceRefresh();
                    this.setupObserver();
                    document.documentElement.setAttribute('data-iconify-loaded', '');
                    this.notifyObservers();
                    this.processPreloadQueue();
                } catch (error) {
                    console.error('Iconify icon render failed:', error);
                }
            }
        }

        const loader = new IconifyLoader();
        window.__iconifyLoader = loader;

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => loader.load());
        } else {
            loader.load();
        }

        window.loadIconify = () => loader.load();
        window.preloadIcons = (icons) => loader.addToPreloadQueue(icons);
        window.onIconifyReady = (cb) => loader.onLoad(cb);
    })();
</script>

<!-- 为不支持JavaScript的情况提供备用方案 -->
<noscript>
    <style>
        iconify-icon {
            display: none;
        }
        .icon-fallback {
            display: inline-block;
        }
    </style>
</noscript>