---
// 全局Iconify加载器组件

export interface Props {
    preloadIcons?: string[];
}

const { preloadIcons = [] } = Astro.props;
---

<!-- 内联加载逻辑: 从 Iconify API 直接获取 SVG，不依赖 CDN 自定义元素 -->
<script define:vars={{ preloadIcons }}>
    (function() {
        'use strict';

        if (window.__iconifyLoaderInitialized) {
            return;
        }
        window.__iconifyLoaderInitialized = true;

        class IconifyLoader {
            constructor() {
                this.isLoaded = false;
                this.observers = new Set();
                this.preloadQueue = new Set(preloadIcons);
                this.svgCache = new Map();
            }

            onLoad(callback) {
                if (this.isLoaded) {
                    callback();
                } else {
                    this.observers.add(callback);
                }
            }

            replaceWithSvg(el, iconName) {
                const svg = this.svgCache.get(iconName);
                if (!svg) return;

                const wrapper = document.createElement('span');
                wrapper.innerHTML = svg;
                const svgEl = wrapper.querySelector('svg');
                if (svgEl) {
                    svgEl.style.width = '1em';
                    svgEl.style.height = '1em';
                    svgEl.style.display = 'inline-block';
                    svgEl.style.verticalAlign = 'middle';
                }

                if (el.parentNode) {
                    el.parentNode.replaceChild(wrapper.firstElementChild || wrapper, el);
                }
            }

            async fetchSvg(iconName) {
                const [collection, name] = iconName.split(':');
                if (!collection || !name) throw new Error(`Invalid icon: ${iconName}`);

                const url = `https://api.iconify.design/${collection}/${name}.svg?height=1em`;
                const response = await fetch(url);
                if (!response.ok) throw new Error(`HTTP ${response.status} for ${iconName}`);

                const text = await response.text();
                return text;
            }

            async renderIcon(el) {
                const iconName = el.getAttribute('icon');
                if (!iconName) return;

                if (this.svgCache.has(iconName)) {
                    this.replaceWithSvg(el, iconName);
                    return;
                }

                try {
                    const svg = await this.fetchSvg(iconName);
                    this.svgCache.set(iconName, svg);
                    this.replaceWithSvg(el, iconName);
                } catch (e) {
                    console.error(`Failed to load icon: ${iconName}`, e);
                }
            }

            async renderAllIcons() {
                const els = document.querySelectorAll('iconify-icon');
                const promises = Array.from(els).map(el => this.renderIcon(el));
                await Promise.allSettled(promises);
            }

            setupObserver() {
                if (this._observer) return;
                const loader = this;
                this._observer = new MutationObserver((mutations) => {
                    if (!loader.isLoaded) return;
                    mutations.forEach(mutation => {
                        mutation.addedNodes.forEach(node => {
                            if (node.nodeType === 1) {
                                if (node.tagName === 'ICONIFY-ICON') {
                                    loader.renderIcon(node);
                                } else if (node.querySelectorAll) {
                                    node.querySelectorAll('iconify-icon').forEach(el => loader.renderIcon(el));
                                }
                            }
                        });
                    });
                });
                this._observer.observe(document.body, { childList: true, subtree: true });
            }

            notifyObservers() {
                this.observers.forEach(cb => { try { cb(); } catch (e) { console.error(e); } });
                this.observers.clear();
            }

            addToPreloadQueue(icons) {
                if (Array.isArray(icons)) {
                    icons.forEach(icon => this.preloadQueue.add(icon));
                } else {
                    this.preloadQueue.add(icons);
                }
                if (this.isLoaded) {
                    this.processPreloadQueue();
                }
            }

            processPreloadQueue() {
                if (this.preloadQueue.size === 0) return;
                const icons = Array.from(this.preloadQueue);
                this.preloadQueue.clear();
                icons.forEach(icon => {
                    if (!this.svgCache.has(icon)) {
                        this.fetchSvg(icon).then(svg => {
                            this.svgCache.set(icon, svg);
                        }).catch(() => {});
                    }
                });
            }

            async load() {
                if (this.isLoaded) return;
                this.isLoaded = true;

                await this.renderAllIcons();
                this.setupObserver();
                this.processPreloadQueue();

                document.documentElement.setAttribute('data-iconify-loaded', '');
                this.notifyObservers();
            }
        }

        const loader = new IconifyLoader();
        window.__iconifyLoader = loader;

        loader.load();

        window.loadIconify = () => loader.load();
        window.preloadIcons = (icons) => loader.addToPreloadQueue(icons);
        window.onIconifyReady = (cb) => loader.onLoad(cb);
    })();
</script>

<noscript>
    <style>
        iconify-icon {
            display: none;
        }
    </style>
</noscript>